export function generateLTXWorkflow(settings: GenerationSettings, prompt: string, negativePrompt: string): object {
  const isGGUF = settings.modelType === 'gguf';
  return {
    "1": { "class_type": isGGUF ? "UnetLoaderGGUF" : "CheckpointLoaderSimple", "inputs": { [isGGUF ? "gguf_name" : "ckpt_name"]: settings.modelFile } },
    "2": { "class_type": "VAELoader", "inputs": { "vae_name": settings.vaeFile } },
    "3": { "class_type": "CLIPLoader", "inputs": { "clip_name": settings.clipFile, "type": "sd" } },
    "4": { "class_type": "CLIPTextEncode", "inputs": { "text": prompt, "clip": ["3", 0] } },
    "5": { "class_type": "CLIPTextEncode", "inputs": { "text": negativePrompt, "clip": ["3", 0] } },
    "6": { "class_type": "EmptyLatentImage", "inputs": { "width": settings.width, "height": settings.height, "batch_size": 1 } },
    "7": { "class_type": "KSampler", "inputs": { "model": ["1", 0], "positive": ["4", 0], "negative": ["5", 0], "latent_image": ["6", 0], "seed": settings.seed, "steps": settings.steps, "cfg": settings.cfgScale, "sampler_name": settings.sampler, "scheduler": settings.scheduler, "denoise": 1.0 } },
    "8": { "class_type": "VAEDecode", "inputs": { "samples": ["7", 0], "vae": ["2", 0] } },
    "9": { "class_type": "VHS_VideoCombine", "inputs": { "images": ["8", 0], "frame_rate": settings.fps, "filename_prefix": "anime_output", "format": "video/h264-mp4", "pix_fmt": "yuv420p" } },
    "10": { "class_type": "SaveImage", "inputs": { "images": ["8", 0], "filename_prefix": "anime_frame" } }
  };
}

