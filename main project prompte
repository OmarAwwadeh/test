export function useLogger() {
  const [logs, setLogs] = useState<LogEntry[]>([]);

  const log = useCallback((level: LogLevel, category: LogCategory, message: string, details?: string, solution?: string) => {
    const entry: LogEntry = {
      id: generateId(), timestamp: new Date().toISOString(), level, category, message, details, solution
    };
    setLogs(prev => [...prev, entry].slice(-500));
    console[level === 'error' ? 'error' : 'log'](`[${category.toUpperCase()}] ${message}`);
  }, []);

  const info = useCallback((cat: LogCategory, msg: string, det?: string) => log('info', cat, msg, det), [log]);
  const success = useCallback((cat: LogCategory, msg: string, det?: string) => log('success', cat, msg, det), [log]);
  const warning = useCallback((cat: LogCategory, msg: string, det?: string, sol?: string) => log('warning', cat, msg, det, sol), [log]);
  const error = useCallback((cat: LogCategory, msg: string, det?: string, sol?: string) => log('error', cat, msg, det, sol), [log]);
  const debug = useCallback((cat: LogCategory, msg: string, det?: string) => log('debug', cat, msg, det), [log]);
  const clearLogs = useCallback(() => setLogs([]), []);

  const exportLogs = useCallback(() => {
    const text = logs.map(l => `[${l.timestamp}] [${l.level.toUpperCase()}] [${l.category}] ${l.message}${l.details ? '\n  Details: ' + l.details : ''}${l.solution ? '\n  Solution: ' + l.solution : ''}`).join('\n');
    const blob = new Blob([text], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `logs-${Date.now()}.txt`; a.click();
    URL.revokeObjectURL(url);
  }, [logs]);

  return { logs, info, success, warning, error, debug, clearLogs, exportLogs };
}

