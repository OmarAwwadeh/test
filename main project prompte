export function useVoice() {
  const [voices, setVoices] = useState<SpeechSynthesisVoice[]>([]);
  const [isPlaying, setIsPlaying] = useState(false);
  const [currentLine, setCurrentLine] = useState<string | null>(null);

  useEffect(() => {
    const loadVoices = () => setVoices(window.speechSynthesis?.getVoices() || []);
    loadVoices();
    window.speechSynthesis?.addEventListener('voiceschanged', loadVoices);
    return () => window.speechSynthesis?.removeEventListener('voiceschanged', loadVoices);
  }, []);

  const findVoice = useCallback((profile: VoiceProfile): SpeechSynthesisVoice | null => {
    const genderVoices = voices.filter(v => {
      const name = v.name.toLowerCase();
      if (profile.gender === 'female') return name.includes('female') || name.includes('woman') || name.includes('zira') || name.includes('samantha');
      if (profile.gender === 'male') return name.includes('male') || name.includes('man') || name.includes('david') || name.includes('daniel');
      return true;
    });
    return genderVoices[0] || voices[0] || null;
  }, [voices]);

  const speak = useCallback((text: string, profile: VoiceProfile, emotion: Emotion = 'neutral') => {
    if (!window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    const voice = findVoice(profile);
    if (voice) utterance.voice = voice;
    const mods = EMOTION_MODIFIERS[emotion] || EMOTION_MODIFIERS.neutral;
    utterance.pitch = Math.max(0.1, Math.min(2, profile.pitch + (mods.pitchShift * 0.1)));
    utterance.rate = Math.max(0.1, Math.min(10, profile.speed * mods.speedMultiplier));
    utterance.volume = Math.max(0, Math.min(1, 1 + (mods.volumeDb * 0.1)));
    utterance.onstart = () => { setIsPlaying(true); setCurrentLine(text); };
    utterance.onend = () => { setIsPlaying(false); setCurrentLine(null); };
    window.speechSynthesis.speak(utterance);
  }, [findVoice]);

  const stop = useCallback(() => {
    window.speechSynthesis?.cancel();
    setIsPlaying(false);
    setCurrentLine(null);
  }, []);

  return { voices, isPlaying, currentLine, speak, stop, findVoice };
}

