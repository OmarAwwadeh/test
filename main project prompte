export function useComfyUI(baseUrl: string, logger: ReturnType<typeof useLogger>) {
  const [status, setStatus] = useState<'connected' | 'disconnected' | 'checking'>('checking');
  const [systemInfo, setSystemInfo] = useState<any>(null);
  const [history, setHistory] = useState<any>(null);

  const checkConnection = useCallback(async () => {
    setStatus('checking');
    try {
      const response = await fetch(`${baseUrl}/system_stats`);
      if (response.ok) {
        const data = await response.json();
        setStatus('connected');
        setSystemInfo(data);
        logger.success('comfyui', 'ComfyUI connected');
      } else throw new Error('Invalid response');
    } catch {
      setStatus('disconnected');
      logger.error('comfyui', 'Cannot connect to ComfyUI', `URL: ${baseUrl}`, 'Ensure ComfyUI is running: python main.py --lowvram --listen');
    }
  }, [baseUrl, logger]);

  const queuePrompt = useCallback(async (workflow: object) => {
    try {
      logger.info('comfyui', 'Queuing workflow...');
      const response = await fetch(`${baseUrl}/prompt`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: workflow })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      logger.success('comfyui', `Prompt queued: ${data.prompt_id}`);
      return data.prompt_id;
    } catch (err: any) {
      logger.error('comfyui', 'Failed to queue workflow', err.message, 'Check ComfyUI console for errors');
      throw err;
    }
  }, [baseUrl, logger]);

  const checkProgress = useCallback(async (promptId: string) => {
    try {
      const response = await fetch(`${baseUrl}/history/${promptId}`);
      if (response.ok) {
        const data = await response.json();
        setHistory(data);
        return data;
      }
    } catch { return null; }
  }, [baseUrl]);

  useEffect(() => { checkConnection(); }, [checkConnection]);

  return { status, systemInfo, history, checkConnection, queuePrompt, checkProgress };
}

