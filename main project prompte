export function parseAIResponseToTranscript(response: string, sceneId: string, characters: Character[]): DialogueLine[] {
  try {
    const parsed = JSON.parse(response);
    let frameCounter = 0;
    return parsed.lines.map((line: any) => {
      const char = characters.find(c => c.name === line.characterName);
      const startFrame = frameCounter;
      const duration = line.duration || 3;
      frameCounter += Math.ceil(duration * 24);
      return {
        id: generateId(), sceneId, characterId: char?.id || '', characterName: line.characterName || 'Unknown',
        text: line.text || '', emotion: line.emotion || 'neutral', startFrame, endFrame: frameCounter,
        startTime: startFrame / 24, endTime: frameCounter / 24, voiceSettings: getEmotionModifiers(line.emotion || 'neutral'),
        notes: ''
      };
    });
  } catch { return []; }
}

export function getEmotionModifiers(emotion: Emotion): VoiceSettings {
  return { ...EMOTION_MODIFIERS[emotion] || EMOTION_MODIFIERS.neutral };
}

export function exportAsSRT(lines: DialogueLine[]): string {
  return lines.map((line, i) => {
    const start = formatSRTTime(line.startTime);
    const end = formatSRTTime(line.endTime);
    return `${i + 1}\n${start} --> ${end}\n[${line.characterName}]: ${line.text}\n`;
  }).join('\n');
}

export function exportAsVTT(lines: DialogueLine[]): string {
  const content = lines.map(line => {
    const start = formatVTTTime(line.startTime);
    const end = formatVTTTime(line.endTime);
    return `${start} --> ${end}\n<v ${line.characterName}>${line.text}</v>`;
  }).join('\n\n');
  return `WEBVTT\n\n${content}`;
}

export function formatSRTTime(seconds: number): string {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  const ms = Math.floor((seconds % 1) * 1000);
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')},${String(ms).padStart(3,'0')}`;
}

export function formatVTTTime(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = Math.floor(seconds % 60);
  const ms = Math.floor((seconds % 1) * 1000);
  return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${String(ms).padStart(3,'0')}`;
}

