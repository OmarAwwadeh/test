export function useOllama(baseUrl: string, logger: ReturnType<typeof useLogger>) {
  const [status, setStatus] = useState<'connected' | 'disconnected' | 'checking'>('checking');
  const [models, setModels] = useState<string[]>([]);

  const checkConnection = useCallback(async () => {
    setStatus('checking');
    try {
      const response = await fetch(`${baseUrl}/api/tags`);
      if (response.ok) {
        const data = await response.json();
        setStatus('connected');
        setModels(data.models?.map((m: any) => m.name) || []);
        logger.success('ollama', `Connected with ${data.models?.length || 0} models`);
      } else throw new Error('Invalid response');
    } catch {
      setStatus('disconnected');
      logger.error('ollama', 'Cannot connect to Ollama', `URL: ${baseUrl}`, 'Install Ollama from https://ollama.com and run: ollama serve');
    }
  }, [baseUrl, logger]);

  const generate = useCallback(async (model: string, system: string, prompt: string) => {
    try {
      logger.info('ollama', 'Generating with Ollama...');
      const response = await fetch(`${baseUrl}/api/generate`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model, system, prompt, stream: false })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      logger.success('ollama', 'Generation complete');
      return data.response;
    } catch (err: any) {
      logger.error('ollama', 'Generation failed', err.message, 'Check Ollama is running and model is installed: ollama pull llama3.2');
      throw err;
    }
  }, [baseUrl, logger]);

  const generateCharacters = useCallback(async (projectName: string, projectDesc: string) => {
    return generate(models[0] || 'llama3.2', OLLAMA_SYSTEM_PROMPT, `Project: ${projectName}\nDescription: ${projectDesc}\n\n${OLLAMA_CHARACTER_PROMPT}`);
  }, [generate, models]);

  const generateTranscript = useCallback(async (sceneDesc: string, characters: string[], style: string) => {
    return generate(models[0] || 'llama3.2', OLLAMA_SYSTEM_PROMPT, `Scene: ${sceneDesc}\nCharacters: ${characters.join(', ')}\nStyle: ${style}\n\n${OLLAMA_TRANSCRIPT_PROMPT}`);
  }, [generate, models]);

  useEffect(() => { checkConnection(); }, [checkConnection]);

  return { status, models, checkConnection, generate, generateCharacters, generateTranscript };
}

